{
  "name": "marmotte",
  "version": "0.3.0",
  "description": "An extensible development toolkit for TypeScript based projects",
  "homepage": "https://github.com/MathisTLD/marmotte#readme",
  "bugs": {
    "url": "https://github.com/MathisTLD/marmotte/issues"
  },
  "license": "ISC",
  "author": "MathisTLD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MathisTLD/marmotte.git"
  },
  "type": "module",
  "bin": {
    "marmotte": "./dist/cli/index.js"
  },
  "exports": {
    "./vitest": "./dist/vitest/index.js",
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./tsconfig/*": "./dist/tsconfig/*"
  },
  "scripts": {
    "build": "vite build",
    "build:docs": "vitepress build docs",
    "dev": "vite build --watch",
    "docs": "vitepress dev docs",
    "test": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "rollup-plugin-node-externals": "^8.1.2",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "unplugin-vue-components": "^31.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress-sidebar": "^1.33.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^13.0.0",
    "@types/node": "*",
    "giget": "^3.1.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "vite": "*",
    "vitepress": "^2.0.0-alpha.16",
    "vitest": "^4.0.18",
    "vue-router": "^5.0.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vitepress": "^2.0.0-alpha.16",
    "vitest": "^4.0.18",
    "vue-router": "^5.0.3"
  },
  "peerDependenciesMeta": {
    "vitepress": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "vue-router": {
      "optional": true
    }
  },
  "overrides": {
    "minimatch": "^10.2.3"
  }
}
