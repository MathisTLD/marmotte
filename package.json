{
  "name": "marmotte",
  "version": "0.1.4",
  "description": "An extensible development toolkit for TypeScript based projects",
  "homepage": "https://github.com/MathisTLD/marmotte#readme",
  "bugs": {
    "url": "https://github.com/MathisTLD/marmotte/issues"
  },
  "license": "ISC",
  "author": "MathisTLD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MathisTLD/marmotte.git"
  },
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./tsconfig/*": "./dist/tsconfig/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@vue/tsconfig": "^0.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "*",
    "rollup-plugin-node-externals": "*",
    "unplugin-dts": "*",
    "vite": "*",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "rollup-plugin-node-externals": "^8.1.2",
    "sass-embedded": "^1.97.3",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.0.0",
    "unplugin-dts": "^1.0.0-beta.6",
    "unplugin-vue-components": "^31.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^7.3.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress": "^2.0.0-alpha.16",
    "vue-router": "^4.6.4"
  }
}